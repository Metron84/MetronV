{
  "buildCommand": "",
  "outputDirectory": ".",
  "rewrites": [
    {
      "source": "/intelligence",
      "destination": "/intelligence.html"
    },
    {
      "source": "/intelligence-brief",
      "destination": "/intelligence-brief.html"
    },
    {
      "source": "/submit-paper",
      "destination": "/submit-paper.html"
    },
    {
      "source": "/submission-received",
      "destination": "/submission-received.html"
    },
    {
      "source": "/subscription-received",
      "destination": "/subscription-received.html"
    },
    {
      "source": "/",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        },
        {
          "key": "X-XSS-Protection",
          "value": "1; mode=block"
        }
      ]
    }
  ]
}
